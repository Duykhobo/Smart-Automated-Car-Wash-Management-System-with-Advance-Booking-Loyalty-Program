### Java ###
# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*
replay_pid*

# Bỏ qua thư mục build của các IDE
build/
target/
out/

# Bỏ qua cấu hình của IntelliJ IDEA
.idea/
*.iml

# Bỏ qua cấu hình của Eclipse
.settings/
.project
.classpath

# Bỏ qua cấu hình của NetBeans
nbproject/private/

# Bỏ qua cấu hình của VS Code
.vscode/

!web/WEB-INF/lib/*.jar

